generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ========== UTILISATEURS ==========

enum Role {
  ADMIN   // Owner / dev : accès total
  TEACHER // Professeur : ne voit/édite que son propre contenu et ses classes
  STUDENT
}

enum SchoolLevel {
  CP
  CE1
  CE2
  CM1
  CM2
}

model User {
  id        Int         @id @default(autoincrement())
  username  String      @unique // format: PrenomN (ex: AdamO, ClemenceP)
  password  String      // hash bcrypt, 5 chars max côté client
  firstName String
  lastName  String
  role      Role        @default(STUDENT)
  level     SchoolLevel? // niveau scolaire propre à l'élève (décorrélé des classes)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations élève
  quizAttempts QuizAttempt[]
  customPaths  CustomPath[]
  classes      Class[]      @relation("StudentClasses") // un élève peut être dans plusieurs classes/groupes

  // Relations prof (contenu créé / classes gérées)
  managedClasses   Class[]    @relation("ClassTeacher")
  createdThemes    Theme[]
  createdSubThemes SubTheme[]
  createdQuizzes   Quiz[]
  createdQuestions Question[]
  createdRevisions Revision[]
  sharedQuizzes    QuizShare[]
  auditLogs        AuditLog[] @relation("AuditActor")

  @@map("users")
}

// Journal d'accès (RGPD art. 30/32) : trace les opérations sensibles sur les
// données d'élèves (consultation de dessins/stats, export, suppression, import).
model AuditLog {
  id         Int      @id @default(autoincrement())
  actorId    Int? // staff ayant effectué l'action (null si compte supprimé)
  action     String // ex: USER_DELETE, STUDENT_EXPORT, STUDENT_STATS_VIEW, DRAWINGS_VIEW
  targetType String? // ex: USER
  targetId   Int?
  detail     String?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

// ========== CLASSES ==========

model Class {
  id        Int         @id @default(autoincrement())
  name      String      @unique // ex: cm2_2, cm1_3
  level     SchoolLevel // niveau scolaire de la classe
  teacherId Int?        // prof gestionnaire de la classe (null = géré par l'Owner)
  createdAt DateTime    @default(now())

  students User[]       @relation("StudentClasses")
  teacher  User?        @relation("ClassTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  quizzes  QuizClass[]

  @@map("classes")
}

// Co-accès en lecture : un quiz partagé à un professeur (lecture seule + stats)
model QuizShare {
  quizId    Int
  teacherId Int

  quiz    Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  teacher User @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@id([quizId, teacherId])
  @@map("quiz_shares")
}

// Ciblage d'un quiz vers des classes (0 ligne = visible par toutes les classes)
model QuizClass {
  quizId  Int
  classId Int

  quiz  Quiz  @relation(fields: [quizId], references: [id], onDelete: Cascade)
  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@id([quizId, classId])
  @@map("quiz_classes")
}

enum QuizVisibility {
  PUBLIC
  PRIVATE
}

// ========== CONTENU PÉDAGOGIQUE ==========

model Theme {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  description String?
  emoji       String     @default("📚")
  order       Int        @default(0)
  createdById Int?       // auteur (null = legacy/Owner)
  createdAt   DateTime   @default(now())

  creator   User?      @relation(fields: [createdById], references: [id], onDelete: SetNull)
  subThemes SubTheme[]

  @@map("themes")
}

model SubTheme {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  order       Int      @default(0)
  themeId     Int
  createdById Int?
  createdAt   DateTime @default(now())

  theme   Theme  @relation(fields: [themeId], references: [id], onDelete: Cascade)
  creator User?  @relation(fields: [createdById], references: [id], onDelete: SetNull)
  quizzes Quiz[]

  // Unicité par créateur : chaque prof peut avoir son propre sous-thème de même nom
  // sous un thème partagé.
  @@unique([themeId, name, createdById])
  @@map("sub_themes")
}

model Quiz {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  timeLimit   Int?     // timer en secondes (null = pas de timer)
  order       Int      @default(0)
  subThemeId  Int
  createdById Int?
  visibility  QuizVisibility @default(PUBLIC) // PUBLIC = tous les élèves ; PRIVATE = élèves du créateur
  createdAt   DateTime @default(now())

  subTheme  SubTheme      @relation(fields: [subThemeId], references: [id], onDelete: Cascade)
  creator   User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  questions Question[]
  attempts  QuizAttempt[]
  customPaths CustomPathQuiz[]
  classes   QuizClass[]
  shares    QuizShare[]

  @@map("quizzes")
}

// ========== QUESTIONS ==========

enum QuestionType {
  QCM          // Choix multiples
  TEXT         // Réponse textuelle
  DRAG_DROP    // Glisser-déposer (items à placer dans des zones)
  ASSOCIATION  // Relier des paires (colonne gauche ↔ colonne droite)
  ORDERING     // Remettre des éléments dans le bon ordre
  DRAWING      // Zone de dessin libre (évaluation manuelle)
}

model Question {
  id         Int          @id @default(autoincrement())
  text       String       // Énoncé de la question
  type       QuestionType
  hint       String?      // Indice affiché en cas d'erreur
  solution   String?      // Explication affichée si l'élève échoue après l'indice
  order      Int          @default(0)
  quizId     Int
  createdById Int?
  createdAt  DateTime     @default(now())

  quiz    Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  creator User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  answers Answer[]
  questionAttempts QuestionAttempt[]
  revisions RevisionQuestion[]

  @@map("questions")
}

model Answer {
  id         Int     @id @default(autoincrement())
  text       String
  isCorrect  Boolean @default(false)
  zone       String? // DRAG_DROP: nom de la zone cible  |  ASSOCIATION: texte de la colonne droite
  order      Int     @default(0) // ORDERING: position attendue (0-indexée)
  questionId Int

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("answers")
}

// ========== PROGRESSION & SCORES ==========

model QuizAttempt {
  id          Int      @id @default(autoincrement())
  userId      Int
  quizId      Int?     // tentative de quiz classique (null si tentative de révision)
  revisionQuizId Int?  // tentative de révision (null si tentative de quiz classique)
  customPathId Int?    // parcours d'où la tentative a été lancée (null = parcours classique par thèmes)
  score       Int      @default(0) // nombre de bonnes réponses
  totalQuestions Int   @default(0)
  completedAt DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz       Quiz?       @relation(fields: [quizId], references: [id], onDelete: Cascade)
  revision   Revision?   @relation(fields: [revisionQuizId], references: [id], onDelete: SetNull)
  customPath CustomPath? @relation(fields: [customPathId], references: [id], onDelete: SetNull)
  questionAttempts QuestionAttempt[]

  @@map("quiz_attempts")
}

enum ValidationStatus {
  NONE     // correction automatique (types autres que dessin)
  PENDING  // dessin en attente de validation par le prof
  APPROVED // dessin validé
  REJECTED // dessin refusé
}

model QuestionAttempt {
  id            Int     @id @default(autoincrement())
  quizAttemptId Int
  questionId    Int
  givenAnswer   String  // réponse donnée par l'élève
  isCorrect     Boolean
  usedHint      Boolean @default(false) // l'élève a-t-il utilisé l'indice ?
  attempts      Int     @default(1) // nombre de tentatives sur cette question
  validationStatus ValidationStatus @default(NONE) // dessins : PENDING/APPROVED/REJECTED

  quizAttempt QuizAttempt @relation(fields: [quizAttemptId], references: [id], onDelete: Cascade)
  question    Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_attempts")
}

// ========== PARCOURS PERSONNALISÉS ==========

model CustomPath {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  userId      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizzes  CustomPathQuiz[]
  attempts QuizAttempt[]

  @@map("custom_paths")
}

model CustomPathQuiz {
  customPathId Int
  quizId       Int
  order        Int @default(0)

  customPath CustomPath @relation(fields: [customPathId], references: [id], onDelete: Cascade)
  quiz       Quiz       @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@id([customPathId, quizId])
  @@map("custom_path_quizzes")
}

// ========== RÉVISIONS PAR NIVEAU ==========

model Revision {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  targetLevel SchoolLevel // niveau scolaire ciblé (CP → CM2)
  endDate     DateTime?   // date de fin optionnelle : au-delà, la révision n'est plus proposée aux élèves
  createdById Int?        // auteur (null = legacy/Owner)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  creator   User?              @relation(fields: [createdById], references: [id], onDelete: SetNull)
  questions RevisionQuestion[]
  attempts  QuizAttempt[]

  @@map("revisions")
}

model RevisionQuestion {
  revisionId Int
  questionId Int
  order      Int @default(0)

  revision Revision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([revisionId, questionId])
  @@map("revision_questions")
}
