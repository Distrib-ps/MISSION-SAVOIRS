# Connexion principale utilisée par l'app (runtime).
# Supabase : utiliser l'URL "pooler" (port 6543).
DATABASE_URL="postgresql://postgres:password@localhost:5432/mission_savoirs"

# Connexion directe utilisée par Prisma Migrate (migrations).
# Supabase : utiliser l'URL "direct" (port 5432).
# En local sans pooling : mettre la même valeur que DATABASE_URL.
DIRECT_URL="postgresql://postgres:password@localhost:5432/mission_savoirs"

# Secret de signature des JWT. OBLIGATOIRE et propre à chaque environnement.
# Générer une valeur forte : openssl rand -base64 48
# Le serveur REFUSE de démarrer si ce secret est absent ou laissé tel quel.
JWT_SECRET="REMPLACER_PAR_UN_SECRET_ALEATOIRE_FORT"
PORT=3001
CLIENT_URL="http://localhost:5173"
